# Neon serverless Postgres connection string.
# Copy this file to `.env.local` for local dev, or set DATABASE_URL in the
# Vercel project settings → Environment Variables for production.
#
# Get this from the Neon dashboard → your project → Connection Details
# (the "pooled" connection works best on Edge runtimes).
DATABASE_URL=postgres://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
